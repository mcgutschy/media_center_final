[Unit]
Description=Media Center GPIO4 Selector (AMP2/Kopfhörer)
After=network.target sound.target
Wants=network-online.target

[Service]
Type=simple
User=sinnie
WorkingDirectory=/home/sinnie/media_center_final/2_sour_media_center
ExecStart=/usr/bin/python3 gpio4_selector.py
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal

Environment=PYTHONUNBUFFERED=1
Environment=HOME=/home/sinnie

KillSignal=SIGTERM
TimeoutStopSec=15

[Install]
WantedBy=multi-user.target
